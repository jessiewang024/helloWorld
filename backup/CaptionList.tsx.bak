"use client";

import { useState } from "react";
import { createSupabaseBrowserClient } from "@/lib/supabase/client";

// Type for a single caption object from the database
interface Caption {
  id: string;
  content: string;
  like_count: number;
  image_id: string;
}

// Props that this component receives from the parent page
interface CaptionListProps {
  captions: Caption[];
  imageMap: Record<string, string>; // maps image_id to image URL
  userId: string | null; // null if user is not logged in
}

// This component displays a list of captions with upvote/downvote buttons
// Only logged-in users can vote
export default function CaptionList({ captions, imageMap, userId }: CaptionListProps) {
  // Create a supabase client for browser-side database calls
  const supabase = createSupabaseBrowserClient();

  // Keep track of which captions the user has already voted on
  // Key is caption ID, value is the vote (1 = upvote, -1 = downvote)
  const [voted, setVoted] = useState<Record<string, number>>({});

  // Handle when user clicks upvote or downvote
  async function handleVote(captionId: string, voteValue: number) {
    // Don't allow voting if not logged in
    if (!userId) {
      return;
    }

    // Insert a new row into the caption_votes table
    const { error } = await supabase.from("caption_votes").insert({
      vote_value: voteValue,
      caption_id: captionId,
      profile_id: userId,
    });

    if (error) {
      // Show an alert if the vote failed
      alert("Vote failed: " + error.message);
    } else {
      // Mark this caption as voted so the buttons get disabled
      let newVoted = { ...voted };
      newVoted[captionId] = voteValue;
      setVoted(newVoted);
    }
  }

  // Show a message if there are no captions
  if (captions.length === 0) {
    return <p>No captions found.</p>;
  }

  return (
    <div style={{ display: "flex", flexDirection: "column", gap: 16 }}>
      {/* Loop through each caption and render a card */}
      {captions.map(function (caption) {
        // Check if user already voted on this caption
        let hasVoted = voted[caption.id] !== undefined;

        return (
          <div
            key={caption.id}
            style={{
              border: "1px solid #ddd",
              borderRadius: 8,
              padding: 16,
              background: "#fafafa",
            }}
          >
            {/* Show the image if we have a URL for it */}
            {imageMap[caption.image_id] && (
              <img
                src={imageMap[caption.image_id]}
                alt=""
                style={{ maxWidth: 300, borderRadius: 8, marginBottom: 12 }}
              />
            )}

            {/* Show the caption text */}
            <p style={{ fontSize: 16, margin: "0 0 12px" }}>{caption.content}</p>

            {/* Voting buttons section */}
            <div style={{ display: "flex", gap: 8, alignItems: "center" }}>
              {/* If user is not logged in, show a message */}
              {!userId && (
                <span style={{ color: "#999", fontSize: 14 }}>
                  Log in to vote
                </span>
              )}

              {/* If user is logged in and already voted, show their vote */}
              {userId && hasVoted && (
                <span style={{ color: "#666" }}>
                  Voted: {voted[caption.id] === 1 ? "Upvoted" : "Downvoted"}
                </span>
              )}

              {/* If user is logged in and has NOT voted yet, show the buttons */}
              {userId && !hasVoted && (
                <>
                  <button
                    onClick={function () { handleVote(caption.id, 1); }}
                    style={{
                      padding: "6px 16px",
                      borderRadius: 4,
                      border: "1px solid #4caf50",
                      background: "#e8f5e9",
                      cursor: "pointer",
                    }}
                  >
                    Upvote
                  </button>
                  <button
                    onClick={function () { handleVote(caption.id, -1); }}
                    style={{
                      padding: "6px 16px",
                      borderRadius: 4,
                      border: "1px solid #f44336",
                      background: "#ffebee",
                      cursor: "pointer",
                    }}
                  >
                    Downvote
                  </button>
                </>
              )}
            </div>
          </div>
        );
      })}
    </div>
  );
}
