/* ===== Global reset ===== */
* {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

/* ===== Theme variables (no Tailwind) ===== */
:root {
  --background: #ffffff;
  --foreground: #171717;
}

/* Dark mode variables */
@media (prefers-color-scheme: dark) {
  :root {
    --background: #0a0a0a;
    --foreground: #ededed;
  }
}

/* ===== Base page styles ===== */
html, body {
  height: 100%;
}

body {
  background: var(--background);
  color: var(--foreground);
  font-family: Arial, Helvetica, sans-serif;
  line-height: 1.5;
}

/* ===== Optional utility classes you can use in pages ===== */
.container {
  max-width: 860px;
  margin: 48px auto;
  padding: 20px;
}

.card {
  background: rgba(255, 255, 255, 0.9);
  border: 1px solid rgba(0,0,0,0.08);
  border-radius: 10px;
  padding: 16px;
}

@media (prefers-color-scheme: dark) {
  .card {
    background: rgba(20, 20, 20, 0.9);
    border: 1px solid rgba(255,255,255,0.12);
  }
}

button {
  padding: 10px 14px;
  border-radius: 8px;
  border: 0;
  cursor: pointer;
  background: #111;
  color: #fff;
  font-size: 14px;
}

button:hover {
  opacity: 0.9;
}

a {
  color: #2563eb;
  text-decoration: none;
}

a:hover {
  text-decoration: underline;
}